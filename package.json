{
    "name": "load-available-actions",
    "version": "0.0.1",
    "private": false,
    "description": "GitHub Action to load all available runner information for an organization",
    "main": "lib/main.js",
    "scripts": {
        "compile": "tsc",
        "esbuild": "esbuild src/main.ts --bundle --outdir=dist --platform=node --external:vscode --external:@vscode/test-electron --external:jest",
        "format": "prettier --write **/*.ts",
        "format-check": "prettier --check **/*.ts",
        "lint": "eslint src/**/*.ts",
        "package": "npm run esbuild",
        "test": "jest --passWithNoTests",
        "all": "npm run esbuild && npm run test # && npm run lint"
    },
    "engines": {
        "node": ">=24"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/devops-actions/load-runner-info.git"
    },
    "keywords": [
        "GitHub Actions",
        "Load available runner information from a GitHub organization"
    ],
    "author": "@rajbos",
    "license": "MIT",
    "dependencies": {
        "@actions/core": "^3.0.1",
        "moment": "^2.30.1",
        "octokit": "^5.0.5",
        "yaml": "^2.9.0"
    },
    "devDependencies": {
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^26.1.1",
        "@typescript-eslint/eslint-plugin": "^8.63.0",
        "@typescript-eslint/parser": "^8.62.1",
        "@vercel/ncc": "^0.44.1",
        "ansi-regex": ">=6.2.2",
        "dotenv": "^17.4.2",
        "esbuild": "^0.28.1",
        "eslint": "^10.7.0",
        "eslint-plugin-github": "^6.1.1",
        "eslint-plugin-jest": "^29.15.4",
        "jest": "^30.4.2",
        "js-yaml": "^5.2.0",
        "prettier": "3.9.5",
        "tmpl": ">=1.0.5",
        "ts-jest": "^29.4.11",
        "typescript": "^6.0.3"
    },
    "optionalDependencies": {
        "fsevents": "^2.3.3"
    }
}
